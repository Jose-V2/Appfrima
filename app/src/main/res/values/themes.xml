<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Appfrima" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="android:windowBackground">@color/background_soft</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_main</item>
    </style>

    <style name="Theme.Appfrima" parent="Base.Theme.Appfrima" />

    <style name="ShapeAppearance.Appfrima.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Appfrima.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.Appfrima.Medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

</resources>